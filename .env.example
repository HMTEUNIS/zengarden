# Copy this file to `.env.local` and fill in your Supabase values.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Supabase default "publishable key" for client/browser usage.
# (Also compatible with older NEXT_PUBLIC_SUPABASE_ANON_KEY if you set that instead.)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=YOUR_PUBLISHABLE_DEFAULT_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Optional:
NEXT_PUBLIC_LIVE_DEMO_MODE=false
LIVE_DEMO_MODE=false

